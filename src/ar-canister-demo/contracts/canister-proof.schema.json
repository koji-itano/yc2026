{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpg.local/schemas/canister-proof.schema.json",
  "title": "Real Physical Gigs Canister Proof Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sessionId",
    "taskId",
    "taskLabel",
    "workerId",
    "taskClass",
    "attemptNumber",
    "taskStep",
    "instruction",
    "provider",
    "fallbackUsed",
    "anchorLockedAt",
    "beforeCapturedAt",
    "instructionCompletedAt",
    "afterCapturedAt",
    "evidence",
    "eventLog",
    "dashboardHandoff",
    "result",
    "readyForVerification",
    "targetId"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "rpg.canister-proof.v1"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "taskLabel": {
      "type": "string",
      "minLength": 1
    },
    "workerId": {
      "type": "string",
      "minLength": 1
    },
    "taskClass": {
      "type": "string",
      "enum": ["green task", "yellow task", "red task"]
    },
    "attemptNumber": {
      "type": "integer",
      "minimum": 1
    },
    "taskStep": {
      "type": "string",
      "minLength": 1
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "enum": ["8thwall", "mindar", "manual"]
    },
    "fallbackUsed": {
      "type": "boolean"
    },
    "anchorLockedAt": {
      "type": "string",
      "format": "date-time"
    },
    "beforeCapturedAt": {
      "type": "string",
      "format": "date-time"
    },
    "instructionCompletedAt": {
      "type": "string",
      "format": "date-time"
    },
    "afterCapturedAt": {
      "type": "string",
      "format": "date-time"
    },
    "evidence": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "eventLog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/eventLogEntry"
      }
    },
    "dashboardHandoff": {
      "$ref": "#/$defs/dashboardHandoff"
    },
    "result": {
      "type": "string",
      "enum": ["proof_submitted", "verified", "needs_retry"]
    },
    "readyForVerification": {
      "type": "boolean"
    },
    "targetId": {
      "type": "string",
      "const": "canister-tabletop-target"
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "capturedAt", "mimeType", "previewDataUrl"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["before", "after"]
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time"
        },
        "mimeType": {
          "type": "string",
          "const": "image/jpeg"
        },
        "previewDataUrl": {
          "type": "string",
          "pattern": "^data:image/jpeg;base64,"
        }
      }
    },
    "eventLogEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["at", "type", "detail"],
      "properties": {
        "at": {
          "type": "string",
          "format": "date-time"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "object"
        }
      }
    },
    "dashboardHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "endpoint", "dispatchedAt", "status"],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "endpoint": {
          "type": ["string", "null"]
        },
        "dispatchedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["ready", "dispatched", "verified", "needs_retry"]
        }
      }
    }
  }
}
